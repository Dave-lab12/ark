#!/usr/bin/env bash
set -euo pipefail

# -----------------------------------------------------------------------------
# ark-ssh: in-container shim that forwards Git's ssh invocations to the host
# Ark broker over a Unix socket (or TCP loopback as a Docker Desktop fallback).
#
# Wire protocol on the socket:
#   header line: "ARKGIT1 <base64(json-request)>\n"            (unix-only)
#              | "ARKGIT1 <token> <base64(json-request)>\n"    (any transport)
#   then raw stdin (the pack/protocol bytes) is streamed through.
# The broker replies with raw bytes on the same connection, which become
# this script's stdout — i.e. Git's view of the remote.
#
# The token form is required on the TCP fallback so that other host-side
# processes running as the same user cannot impersonate the container.
# -----------------------------------------------------------------------------

sock="${ARK_GIT_BROKER_SOCK:-/run/ark/git-broker.sock}"
connect_timeout="${ARK_GIT_BROKER_TIMEOUT:-10}"

# --- request payload ---------------------------------------------------------
# argv as a JSON array of strings.
argv_json="$(
    printf '%s\n' "$@" \
        | jq -R . \
        | jq -s -c .
)"

# Forward only env vars the host broker / Git actually needs. The container
# environment may contain project secrets (API tokens, DB URLs, etc.); the
# broker has no business seeing them. Whitelist beats blacklist here.
#
# Skip GIT_SSH / GIT_SSH_COMMAND — they point at this very script and mean
# nothing on the host side.
env_json="$(
    env \
        | grep -E '^(GIT_|LANG=|LC_|TERM=)' \
        | grep -Ev '^GIT_SSH(_COMMAND)?=' \
        | jq -R 'split("=") | {(.[0]): (.[1:] | join("="))}' \
        | jq -s -c 'add // {}'
)"

request="$(
    jq -nc \
        --argjson argv "${argv_json}" \
        --argjson env  "${env_json}" \
        --arg cwd      "${PWD}" \
        '{argv: $argv, env: $env, cwd: $cwd}'
)"

send_request() {
    local payload
    payload="$(printf '%s' "${request}" | base64 | tr -d '\n')"
    if [[ -n "${ARK_GIT_BROKER_TOKEN:-}" ]]; then
        printf 'ARKGIT1 %s %s\n' "${ARK_GIT_BROKER_TOKEN}" "${payload}"
    else
        printf 'ARKGIT1 %s\n' "${payload}"
    fi
    # Stream Git's stdin (pack data, protocol bytes) on to the broker.
    cat
}

# --- transport selection -----------------------------------------------------
# Pre-flight the unix socket with a zero-byte connect probe. This avoids the
# "stdin already consumed" trap that breaks naive retry logic: we decide on
# the transport BEFORE we start streaming Git's stdin.
preflight_unix() {
    [[ -S "${sock}" ]] || return 1
    socat -T 1 /dev/null "UNIX-CONNECT:${sock}" 2>/dev/null
}

if preflight_unix; then
    transport="UNIX-CONNECT:${sock}"
elif [[ -n "${ARK_GIT_BROKER_TCP:-}" ]]; then
    transport="TCP:${ARK_GIT_BROKER_TCP}"
else
    echo "ark-ssh: cannot reach broker at ${sock} and no ARK_GIT_BROKER_TCP set" >&2
    exit 255
fi

# --- run ---------------------------------------------------------------------
# -t controls how long socat waits after one side closes before tearing down
# the other half — keep it short so a half-closed broker doesn't wedge git.
exec socat -t 5 - "${transport}" < <(send_request)
